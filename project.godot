; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="platformer-2"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.827451, 0.6313726, 0.57254905, 1)
config/icon="res://icon.svg"

[display]

window/size/mode=2

[editor_plugins]

enabled=PackedStringArray("res://addons/trail_2d/plugin.cfg")

[global_group]

Player=""

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method.mobile="forward_plus"
environment/defaults/default_clear_color=Color(0.7497437, 0.5177679, 0.42440957, 1)
